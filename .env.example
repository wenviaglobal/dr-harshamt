# ─── WhatsApp Cloud API Credentials ───
# Setup: https://developers.facebook.com → Create App → Add WhatsApp product
#
# 1. Go to developers.facebook.com
# 2. Create a Business App
# 3. Add "WhatsApp" product
# 4. Go to WhatsApp > API Setup
# 5. Copy Phone Number ID and generate a permanent Access Token
# 6. Add the doctor's personal WhatsApp number as a recipient

WA_PHONE_NUMBER_ID=your_phone_number_id_here
WA_ACCESS_TOKEN=your_access_token_here
DOCTOR_WHATSAPP=917483749378
